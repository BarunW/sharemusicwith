# Build artifacts are produced inside the image — don't ship stale copies.
# (wasm_exec.js is regenerated by the TinyGo build stage; the committed copy is
# only for local serving and must not shadow/overwrite the in-image one.)
main.wasm
wasm_exec.js
server
cwp-server-bin
.gocache

# Not needed in the image.
*.md
.env
deploy/
