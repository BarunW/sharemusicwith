# Copy to .env and fill in. The real .env is gitignored.
# Generate secrets with: openssl rand -hex 32

# Image to run, built + pushed by CI (.github/workflows/deploy.yml). Use the GHCR
# ref for your repo, e.g. the staging-branch tag:
APP_IMAGE=ghcr.io/OWNER/REPO:staging

# Your domain. Only used by the optional Caddy profile; host nginx reads it from
# the vhost. Point an A record at the VM before issuing a cert.
DOMAIN=staging.yourdomain.com

POSTGRES_PASSWORD=replace-with-long-random
# Stable secret — rotating it resets per-visitor view/click dedup history.
# If unset, events are stored but NEVER counted in rankings (feed stays empty).
METRICS_SALT=replace-with-long-random-secret
